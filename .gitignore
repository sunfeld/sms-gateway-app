# Built application files
*.apk
*.aar
*.ap_
*.aab

# Files for the ART/Dalvik VM
*.dex

# Java class files
*.class

# Generated files
bin/
gen/
out/
release/

# Gradle files
.gradle/
build/
app/build/

# Local configuration file (sdk path, etc)
local.properties

# Proguard folder generated by Eclipse
proguard/

# Log files
*.log

# Android Studio
*.iml
.idea/
.idea/workspace.xml
.idea/tasks.xml
.idea/gradle.xml
.idea/assetWizardSettings.xml
.idea/dictionaries
.idea/libraries
.idea/caches
.idea/modules.xml
.idea/misc.xml
.idea/vcs.xml
.idea/jarRepositories.xml
.idea/navEditor.xml

# Android Studio Navigation editor temp files
.navigation/

# OS-specific files
.DS_Store
Thumbs.db

# Captures (Android Studio profiling)
captures/

# IntelliJ
*.iws
.idea_modules/

# Keystore files (keep out of version control)
*.jks
*.keystore

# External native build folder generated in Android Studio 2.2 and later
.externalNativeBuild/
.cxx/

# Google Services (if used)
google-services.json

# Gradle wrapper jar (optionally check in)
# gradle/wrapper/gradle-wrapper.jar
